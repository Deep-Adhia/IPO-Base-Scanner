# Telegram Bot Settings
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id_or_group_id

# Scanner Configuration
IPO_YEARS_BACK=2           # Number of years to fetch IPOs
STOP_PCT=0.03              # Base trailing stop (%)
PT_A_PLUS=0.15             # Partial take for A+ grade
PT_B=0.12                  # Partial take for B grade
PT_C=0.10                  # Partial take for C grade

CONSOL_WINDOWS=10,20,40,80,120  # Consolidation windows (comma-separated)
VOL_MULT=1.2                   # Volume multiplier threshold
ABS_VOL_MIN=3000000            # Absolute volume minimum
LOOKAHEAD=80                   # Lookahead days after consolidation
MAX_DAYS=200                   # Max days to search for breakout
MAX_FLAT_HOLD_WEEKS=20

# Caching & Files
CACHE_FILE=ipo_cache.pkl
SIGNALS_CSV=ipo_signals.csv
POSITIONS_CSV=ipo_positions.csv

# Heartbeat (days between heartbeat alerts; 0 = off)
HEARTBEAT_RUNS=0

# --- Listing day breakout (listing_day_breakout_scanner.py) ---
# STRICT (default true): only CSV + positions when volume + freshness pass (no LOW_VOL spam)
LISTING_STRICT_QUALITY=true
# LISTING_STRICT_QUALITY=false   # back to old behaviour: low-vol breakouts saved with caution
LISTING_CONFIRMATION_MINUTES=60          # hold-above-breakout window before entry (0 disables pending-confirmation)
LISTING_MIN_LEADER_SCORE=5               # minimum leader score to allow BREAKOUT entry

LISTING_MIN_VOLUME_MULT=1.8           # current vol vs ~10d avg (strict default)
LISTING_MIN_VOL_VS_LISTING=1.0         # today vol vs listing-day vol (when listing vol > 0)
LISTING_MIN_VOL_MULT_WHEN_NO_LISTING_VOL=2.0   # if listing-day vol missing in CSV
LISTING_MAX_ENTRY_ABOVE_HIGH_PCT=3.5  # max % above listing high for entry
LISTING_MIN_RISK_REWARD=1.25          # min reward:risk
LISTING_MAX_DAYS_SINCE_LISTING=60     # skip breakouts on very old IPOs
LISTING_STOP_LOSS_PCT=8

# Consolidation live scanner (streamlined-ipo-scanner.py)
MIN_RISK_REWARD=1.3
MAX_ENTRY_ABOVE_BREAKOUT_PCT=8
MIN_LIVE_GRADE=C
MIN_DAYS_BETWEEN_SIGNALS=10
