# Telegram Bot Settings
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id_or_group_id

# Scanner Configuration
IPO_YEARS_BACK=2           # Number of years to fetch IPOs
STOP_PCT=0.03              # Base trailing stop (%)
PT_A_PLUS=0.15             # Partial take for A+ grade
PT_B=0.12                  # Partial take for B grade
PT_C=0.10                  # Partial take for C grade

CONSOL_WINDOWS=10,20,40,80,120  # Consolidation windows (comma-separated)
VOL_MULT=1.2                   # Volume multiplier threshold
ABS_VOL_MIN=3000000            # Absolute volume minimum
LOOKAHEAD=80                   # Lookahead days after consolidation
MAX_DAYS=200                   # Max days to search for breakout
MAX_FLAT_HOLD_WEEKS=20

# Caching & Files
CACHE_FILE=ipo_cache.pkl
SIGNALS_CSV=ipo_signals.csv
POSITIONS_CSV=ipo_positions.csv

# Heartbeat (days between heartbeat alerts; 0 = off)
HEARTBEAT_RUNS=0

# --- Listing day breakout (listing_day_breakout_scanner.py) ---
# STRICT (default true): only CSV + positions when volume + freshness pass (no LOW_VOL spam)
LISTING_STRICT_QUALITY=true
# LISTING_STRICT_QUALITY=false   # back to old behaviour: low-vol breakouts saved with caution
LISTING_CONFIRMATION_MINUTES=60          # hold-above-breakout window before entry (0 disables pending-confirmation)
LISTING_MIN_LEADER_SCORE=5               # minimum leader score to allow BREAKOUT entry

LISTING_MIN_VOLUME_MULT=1.8           # current vol vs ~10d avg (strict default)
LISTING_MIN_VOL_VS_LISTING=1.0         # today vol vs listing-day vol (when listing vol > 0)
LISTING_MIN_VOL_MULT_WHEN_NO_LISTING_VOL=2.0   # if listing-day vol missing in CSV
LISTING_MAX_ENTRY_ABOVE_HIGH_PCT=3.5  # max % above listing high for entry
LISTING_MIN_RISK_REWARD=1.25          # min reward:risk
LISTING_MAX_DAYS_SINCE_LISTING=60     # skip breakouts on very old IPOs
LISTING_STOP_LOSS_PCT=8

# Watchlist (attention layer) — strict mode only; aligns with IPO momentum, not “any old stock near a level”
LISTING_WATCHLIST_ABSOLUTE_MAX_AGE_DAYS=120 # hard reject: older = normal stock, not IPO-base playbook
LISTING_WATCHLIST_MAX_DAYS_SINCE_LISTING=90 # target IPO freshness for watchlist
# Volume vs ~10d avg: 0 = no filter. Set min e.g. 1.2 for “active” only, or max e.g. 1.05 for dry-up only.
LISTING_WATCHLIST_MIN_VOLUME_MULT=0
LISTING_WATCHLIST_MAX_VOL_VS_AVG=0
# “Perfect base” checklist (last N daily bars)
LISTING_WATCHLIST_BASE_LOOKBACK=7
LISTING_WATCHLIST_MAX_BASE_RANGE_PCT=9      # tight range vs avg price (8–10% zone)
LISTING_WATCHLIST_AUTO_REJECT_WIDE_RANGE_PCT=12
LISTING_WATCHLIST_MIN_CLOSE_IN_RANGE_PCT=45
LISTING_WATCHLIST_REQUIRE_RANGE_CONTRACTION=true
LISTING_WATCHLIST_MIN_DISTANCE_FROM_HIGH_PCT=3
LISTING_WATCHLIST_MAX_DISTANCE_FROM_HIGH_PCT=5
LISTING_WATCHLIST_VOL_DRYUP_RECENT_DAYS=5
LISTING_WATCHLIST_VOL_DRYUP_PRIOR_DAYS=10
LISTING_WATCHLIST_VOL_DRYUP_MAX_RATIO=0.8
LISTING_WATCHLIST_REQUIRE_VOL_DRYUP=true
LISTING_WATCHLIST_MIN_SUPPORT_TOUCHES=2
LISTING_WATCHLIST_SUPPORT_TOUCH_TOLERANCE_PCT_OF_RANGE=1.5
LISTING_WATCHLIST_MAX_UPPER_WICK_OF_HIGH_PCT=4
LISTING_WATCHLIST_MAX_UPPER_WICK_OF_BAR_FRAC=0.55
LISTING_WATCHLIST_NEAR_HIGH_ZONE_PCT=1.5
LISTING_WATCHLIST_NEAR_HIGH_DUMP_PCT=3.5
LISTING_WATCHLIST_MAX_NEAR_HIGH_DUMP_DAYS=2
LISTING_WATCHLIST_REJECT_FALLING_VOL_AND_PRICE=true
LISTING_WATCHLIST_MAX_SIGN_FLIPS=4
LISTING_WATCHLIST_MIN_LEADER_SCORE=5

# Consolidation live scanner (streamlined-ipo-scanner.py)
MIN_RISK_REWARD=1.3
MAX_ENTRY_ABOVE_BREAKOUT_PCT=8
MIN_LIVE_GRADE=C
MIN_DAYS_BETWEEN_SIGNALS=10

# --- Tiered strategy: A+ / A / B / controlled-fallback A ---
# Tier A+: perfect base + listing-high breakout + volume ≥ 1.8× + age ≤ 60d → 100% size
LISTING_TIER_APLUS_MIN_VOLUME_MULT=1.8
LISTING_TIER_APLUS_MAX_AGE_DAYS=60

# Tier A: pure momentum — strong volume, no base, NOT perfect base, age ≤ 45d → 60% size
LISTING_TIER_A_MIN_VOLUME_MULT=2.0
LISTING_TIER_A_MAX_AGE_DAYS=45

# Tier A — controlled fallback: vol ≥ 1.8×, age ≤ 75d → 50% size (edge-extender, not main system)
LISTING_TIER_A_FALLBACK_MAX_AGE_DAYS=75
LISTING_TIER_A_FALLBACK_POSITION_SIZE_PCT=50

# Tier B: base breakout below listing high (accumulation-driven) → 40% size
LISTING_TIER_B_ENABLED=true
LISTING_TIER_B_MAX_DISTANCE_FROM_HIGH_PCT=20  # max % below listing high to still consider
LISTING_TIER_B_MAX_AGE_DAYS=90
LISTING_TIER_B_POSITION_SIZE_PCT=40

# Post-confirm weak-move filter: price must have moved ≥ this % beyond breakout level after confirm
# Kills slow/dead breakouts. Set 0 to disable.
LISTING_MIN_POST_CONFIRM_MOVE_PCT=1.5
